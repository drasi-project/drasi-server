{
    "name": "Drasi Server - Trading Demo",
    "image": "mcr.microsoft.com/devcontainers/rust:1-bookworm",
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": true
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "22"
        },
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.12"
        }
    },
    "initializeCommand": "docker network inspect drasi-network || docker network create drasi-network",
    "postCreateCommand": "bash .devcontainer/trading/post-create.sh",
    // Attach to the shared `drasi-network` so the dev container can reach
    // the `trading-postgres` container by hostname. Because a custom Docker
    // network disables Docker's automatic host port publishing AND because
    // VS Code's `forwardPorts` tunnel is unreliable on Docker Desktop with
    // custom networks (the Ports panel shows the port but the host never
    // actually binds it), we publish the demo ports explicitly with `-p`
    // so `http://localhost:<port>` works in the host browser without
    // depending on VS Code's auto-forwarder.
    "runArgs": [
        "--network=drasi-network",
        "-p",
        "5273:5273",
        "-p",
        "8280:8280",
        "-p",
        "8281:8281",
        "-p",
        "9100:9100",
        "-p",
        "9200:9200"
    ],
    "forwardPorts": [
        8280,
        9100,
        5632,
        5273
    ],
    "portsAttributes": {
        "8280": {
            "label": "Drasi Server API",
            "onAutoForward": "notify"
        },
        "9100": {
            "label": "HTTP Source",
            "onAutoForward": "silent"
        },
        "5632": {
            "label": "PostgreSQL",
            "onAutoForward": "silent"
        },
        "5273": {
            "label": "Trading App",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                "humao.rest-client",
                "serayuzgur.crates",
                "vadimcn.vscode-lldb"
            ],
            "settings": {
                "rust-analyzer.cargo.features": "all",
                "rust-analyzer.check.command": "clippy",
                "editor.formatOnSave": true
            }
        }
    },
    "remoteUser": "vscode",
    "containerEnv": {
        "RUST_BACKTRACE": "1",
        "HOST_WORKSPACE_FOLDER": "${localWorkspaceFolder}",
        // The trading_api.py (and other helpers under examples/trading/mock-generator)
        // default to POSTGRES_HOST=localhost / POSTGRES_PORT=5632, which only works
        // when running on the host machine where docker-compose publishes 5632:5432.
        // Inside this dev container Postgres is reached via the shared
        // `drasi-network` as `trading-postgres:5432`. Without these overrides,
        // start-demo.sh aborts at "Waiting for Trading API to be ready" because
        // the API health check returns 500 (connection refused on localhost:5632).
        "POSTGRES_HOST": "trading-postgres",
        "POSTGRES_PORT": "5432"
    }
}